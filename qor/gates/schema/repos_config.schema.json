{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://qor-logic.mythologiq/schemas/repos_config.schema.json",
  "title": "Cross-Repo Shadow Genome Collector Config",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "meta_repo", "repos", "threshold", "stale_days"],
  "properties": {
    "version": { "type": "string", "const": "1" },
    "meta_repo": {
      "description": "owner/name of the GitHub repo where consolidated issues open",
      "type": "string",
      "pattern": "^[^/]+/[^/]+$"
    },
    "repos": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "name", "enabled"],
        "properties": {
          "path": { "type": "string", "minLength": 1 },
          "name": { "type": "string", "minLength": 1 },
          "enabled": { "type": "boolean" }
        }
      }
    },
    "threshold": { "type": "integer", "minimum": 1 },
    "stale_days": { "type": "integer", "minimum": 1 }
  }
}
