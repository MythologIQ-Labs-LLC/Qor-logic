{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Compliance Control Matrix",
  "type": "object",
  "required": ["schema_version", "controls", "waivers"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {"type": "string"},
    "controls": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id", "framework", "control", "enforcing_module",
          "posture", "detection", "wired_into", "variants", "engagement"
        ],
        "additionalProperties": false,
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "framework": {"type": "string", "minLength": 1},
          "control": {"type": "string", "minLength": 1},
          "enforcing_module": {"type": "string", "minLength": 1},
          "invocation": {"type": "string"},
          "posture": {"type": "string", "enum": ["ABORT", "WARN"]},
          "detection": {"type": "string", "enum": ["skill-marker", "test", "ci-job"]},
          "wired_into": {"type": "object"},
          "variants": {"type": "array", "items": {"type": "string"}},
          "engagement": {
            "type": "array",
            "minItems": 1,
            "items": {"enum": ["pre-commit", "pre-push", "pre-tool-write", "ci", "seal"]}
          },
          "runner": {
            "oneOf": [
              {"type": "null"},
              {
                "type": "object",
                "required": ["module", "entry", "args"],
                "additionalProperties": false,
                "properties": {
                  "module": {"type": "string", "minLength": 1},
                  "entry": {"type": "string", "minLength": 1},
                  "args": {"type": "array", "items": {"type": "string"}},
                  "requires": {"type": "array", "items": {"type": "string"}}
                }
              }
            ]
          },
          "runner_unavailable_reason": {"type": "string", "minLength": 1}
        }
      }
    },
    "waivers": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "justification", "issue"],
        "additionalProperties": false,
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "justification": {"type": "string", "minLength": 1},
          "issue": {"type": "string", "minLength": 1}
        }
      }
    }
  }
}
